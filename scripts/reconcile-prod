#!/usr/bin/env bash
# Run `case-calendar reconcile` on prod. Pass extra args through, e.g.
#   ./scripts/reconcile-prod
#   ./scripts/reconcile-prod --case us-v-knoot
#   ./scripts/reconcile-prod --days 14
#
# `reconcile` re-checks only the entries that arrived as placeholders (one
# CourtListener request each) to pick up the upstream enrichment a webhook
# delivery can't see — cheap to run often regardless of caseload. See
# docs/cli.md and CourtListener issue #7423.
#
# Does NOT stop the service — reconcile and serve are safe to run
# concurrently (WAL journaling + busy_timeout cover the cross-process write
# contention), exactly like sync-prod.
#
# Reads the prod connection settings from .env (gitignored, NOT in
# .env.example): CC_PROD_HOST, CC_PROD_SSH_USER, CC_PROD_APP_DIR,
# CC_PROD_SERVICE. See scripts/_prod-env.sh for what each one is.

set -euo pipefail

# shellcheck source=scripts/_prod-env.sh
source "$(dirname "$0")/_prod-env.sh"

if ! ssh-add -l >/dev/null 2>&1; then
    ssh-add
fi

# PYTHONUNBUFFERED=1 so case-calendar's stdout streams to this terminal
# in real time instead of being block-buffered (python's default when it
# detects its stdout isn't a TTY, which it isn't on the far end of ssh).
# `sudo` doesn't preserve env vars by default, so wrap with `env` to set
# it inside the service account's environment.
ssh "$CC_PROD_SSH" \
    "cd $CC_PROD_APP_DIR && sudo -u $CC_PROD_SERVICE env PYTHONUNBUFFERED=1 ./.local/bin/uv run case-calendar reconcile $*"
