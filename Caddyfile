# Caddyfile for case-calendar.
#
# This file is checked in as a working template — edit the domain + paths
# below to match your deployment. The distro Caddy package reads
# /etc/caddy/Caddyfile, so the typical install is to symlink (or copy)
# this file there:
#
#   ln -s /opt/case-calendar/Caddyfile /etc/caddy/Caddyfile
#   systemctl reload caddy
#
# Caddy serves the contents of ./out at the site root over HTTPS, with
# automatic Let's Encrypt certs. Subscribers point their calendar app at:
#
#   https://calendars.example.com/<calendar>.ics
#
# and the index.html generated by `case-calendar emit` is served at:
#
#   https://calendars.example.com/
#
# Replace `calendars.example.com` below with your own domain. Caddy needs
# inbound TCP/80 + TCP/443 reachable from the public internet for the ACME
# HTTP-01 challenge to succeed; use the DNS-01 plugin if you're behind a
# firewall.
#
# Run with:
#   caddy run --config /path/to/case-calendar/Caddyfile
#
# Or, under the distro systemd unit, install at /etc/caddy/Caddyfile and
# `systemctl enable --now caddy`.

calendars.example.com {
	# Absolute path to the case-calendar `out/` directory. The default
	# layout puts ICS files (cybercrime.ics, tech.ics, ...) and the
	# generated index.html in the same directory, so a single file_server
	# directive covers both.
	root * /home/sean/dev/case-calendar/out
	file_server {
		# Serve index.html for the bare site root rather than a
		# directory listing — keeps the auto-generated index page
		# from being shadowed by Caddy's default browse view.
		index index.html
	}

	# .ics files should be served with the calendar MIME type so clients
	# treat the download as a subscription rather than plain text.
	@ics path *.ics
	header @ics Content-Type "text/calendar; charset=utf-8"

	# Subscribe URLs change rarely (the calendar list lives in
	# config.yaml). Short-circuit conditional requests so refreshing
	# clients don't redownload an unchanged feed.
	header Cache-Control "public, max-age=300"

	# Optional structured access log for ops visibility.
	# log {
	#     output file /var/log/caddy/case-calendar.log
	# }
}

# Optional: reverse proxy for the `case-calendar serve` webhook receiver.
#
# Run the receiver locally (it binds 127.0.0.1 by default — keep it that
# way, Caddy is the only thing that should reach it from outside):
#
#   uv run case-calendar serve --port 8000
#
# Then uncomment this block, point a subdomain at the same host, and
# register the resulting URL in the CourtListener dashboard:
#
#   https://webhook.example.com/webhooks/case-calendar/<CASE_CALENDAR_WEBHOOK_SECRET>
#
# The path-secret is the only thing keeping forged events out — CL
# doesn't sign webhook payloads — so keep the URL out of logs (Caddy
# scrubs query strings but logs paths by default) and rotate the
# secret if it ever leaks.
#
# webhook.example.com {
# 	reverse_proxy 127.0.0.1:8000
#
# 	# CL retries failed deliveries; the receiver's own Idempotency-Key
# 	# dedup makes that safe. Don't add aggressive rate limits here or
# 	# you'll throw away legitimate retry traffic.
# }
