.env
.venv/
config.yaml
.coverage
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# Generated state and outputs — keep the directories themselves (via
# .gitkeep) so the systemd unit's ReadWritePaths= can bind-mount them on
# a fresh checkout, before sync / emit / OAuth setup has populated them.
data/*
!data/.gitkeep
out/*
!out/.gitkeep
tokens/*
!tokens/.gitkeep

# Local user config
.local/
.config/
.profile
.bash_history
.bashrc
.zshrc
.claude/scheduled_tasks.lock
scripts/*.json

# Local-only operational scripts (deploy creds, host-specific commands).
private/
