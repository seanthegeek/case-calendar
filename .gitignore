.env
.venv/
config.yaml
.coverage
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# Generated state and outputs — keep the directories themselves (via
# .gitkeep) so the systemd unit's ReadWritePaths= can bind-mount them on
# a fresh checkout, before sync / emit / OAuth setup has populated them.
data/*
!data/.gitkeep
out/*
!out/.gitkeep
tokens/*
!tokens/.gitkeep

# Transient run log from model-comparison/build_provider_stores.py.
model-comparison/*.log

# Per-build cost report written by `build_provider_stores.py --out
# model-comparison/cost.md`. The committed cost numbers live in
# `model-comparison/SCORECARD.md`; this file is just the build's own
# scratch report and shouldn't go in git. The dot-suffixed variants
# (e.g. `cost.temp0-slim.md`) are scratch outputs from comparison
# sweeps where the operator preserved several builds side by side.
model-comparison/cost.md
model-comparison/cost.*.md

# Per-run scorer report written by `score_models.py --out model-comparison/score.md`.
# The committed analysis is hand-curated in `model-comparison/SCORECARD.md`; this
# is just the scorer's own scratch output and shouldn't go in git.
model-comparison/score.md
model-comparison/score.*.md

# Benchmark-input snapshots (model-comparison/snapshot_benchmark.py): the
# SQLite file is large + binary, so it's tracked via Git LFS (see .gitattributes)
# and committed — run `git lfs pull` after clone to fetch it — NOT gitignored.
# Its sibling *.manifest.json (date, row counts, checksums incl. the paired
# ground_truth.csv sha256) is committed normally. Only the transient WAL
# sidecars are ignored (a backup-API snapshot is a single file, so these
# normally don't exist; ignored defensively).
model-comparison/snapshots/*.sqlite-*

# Per-entry ground-truth scoring page (model-comparison/build_scoring_page.py):
# large generated HTML, regenerable from the committed benchmark snapshot. The
# human's FILLED scores download to model-comparison/ground_truth.csv (committed
# normally), not here.
model-comparison/scoring/

# Local user config
.local/
.config/
.profile
.bash_history
.bashrc
.zshrc
.claude/scheduled_tasks.lock
scripts/*.json

#LibreOffice lock files
*~lock.*#

# Local-only scratch space (anything host-specific you don't want tracked).
# The deployment scripts that used to live here are now in scripts/, with
# their identifying values read from .env (see scripts/_prod-env.sh).
private/
