.env
.venv/
config.yaml
.coverage
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# Generated state and outputs — keep the directories themselves (via
# .gitkeep) so the systemd unit's ReadWritePaths= can bind-mount them on
# a fresh checkout, before sync / emit / OAuth setup has populated them.
data/*
!data/.gitkeep
out/*
!out/.gitkeep
tokens/*
!tokens/.gitkeep

# Per-build cost report written by `build_provider_stores.py --out
# model-comparison/cost.md`. The committed cost numbers live in
# `model-comparison/SCORECARD.md`; this file is just the build's own
# scratch report and shouldn't go in git. The dot-suffixed variants
# (e.g. `cost.temp0-slim.md`) are scratch outputs from comparison
# sweeps where the operator preserved several builds side by side.
model-comparison/cost.md
model-comparison/cost.*.md

# Local user config
.local/
.config/
.profile
.bash_history
.bashrc
.zshrc
.claude/scheduled_tasks.lock
scripts/*.json

#LibreOffice lock files
*~lock.*#

# Local-only scratch space (anything host-specific you don't want tracked).
# The deployment scripts that used to live here are now in scripts/, with
# their identifying values read from .env (see scripts/_prod-env.sh).
private/
