# CourtListener API token — get one at https://www.courtlistener.com/profile/api/
COURTLISTENER_TOKEN=

# LLM Provider: "anthropic", "gemini", or "openai"
# Sets the default provider for BOTH the extraction track and the case-
# summary track. Anthropic is the default because it loads the legal-
# vocabulary priors needed to classify substantive federal-procedure
# deadlines (PSR, Speedy Trial Act exclusions, surrender for service of
# sentence, civil-forfeiture claim/answer, sealing motion practice,
# etc.) as major without an explicit prompt-vocabulary list — see
# model-comparison/SCORECARD.md for the maintenance-treadmill reasoning
# behind the 0.10.0 reversion of the brief 0.9.0 Gemini-default flip.
# If neither LLM_PROVIDER nor any per-track override is set, auto-
# detects based on which API key is present (priority:
# anthropic > gemini > openai).
LLM_PROVIDER=anthropic

# Extraction track override (per-entry classification + verify pass +
# dedupe). Beats LLM_PROVIDER for the extraction track only. Set this
# to "gemini" if you've verified Gemini handles your caseload's
# substantive-class profile (the published comparison ranks it best on
# deviation and it's substantially faster + cheaper than Anthropic).
# Leave unset to use the LLM_PROVIDER global default.
# LLM_EXTRACTION_PROVIDER=anthropic

# Model override for the extraction track. Defaults below are
# small/fast — structured extraction doesn't need flagship reasoning.
#   Anthropic: claude-haiku-4-5
#   Gemini:    gemini-3.1-flash-lite
#   OpenAI:    gpt-5.4-nano
# LLM_MODEL=claude-haiku-4-5

# Case-summary track (opt-in via case_summaries.enabled in config.yaml).
# Synthesis-heavy, low-volume — defaults to a higher tier than
# extraction. LLM_SUMMARY_PROVIDER beats LLM_PROVIDER for the summary
# track only; leave both unset and the summary track picks up the
# global default. Config-level `case_summaries.provider` / `.model`
# win over either env var if set.
#   Anthropic: claude-sonnet-4-6
#   Gemini:    gemini-2.5-pro
#   OpenAI:    gpt-5.4
# LLM_SUMMARY_PROVIDER=anthropic
# LLM_SUMMARY_MODEL=claude-sonnet-4-6

# API Keys — set the one matching your provider
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Webhook receiver secret (only needed if you run `case-calendar serve` for
# real-time push from CourtListener). Generate one with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# CASE_CALENDAR_WEBHOOK_SECRET=

# --- Calendar push (all optional) -------------------------------------------
#
# Google Calendar: there is NO env var. Put the path to your downloaded
# OAuth-installed-app JSON in config.yaml as `google_credentials_path`.
# First run of `case-calendar emit --push-gcal` opens a browser and caches
# the refresh token at `google_token_path` (default
# tokens/google-token.json, relative to the project directory).
#
# Microsoft 365 / Outlook: the Application (client) ID of your Entra
# "public client" app registration. This is a PUBLIC identifier, not a
# secret — put it here OR in config.yaml as `m365_client_id` (config
# wins if both are set). The interactive first-run of
# `case-calendar emit --push-m365` opens a browser to grant
# Calendars.ReadWrite and caches the AuthenticationRecord at
# `m365_token_path` (default tokens/m365-token.json) plus the
# OS keyring (DPAPI / Keychain / libsecret).
# M365_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Optional logging level
# LOG_LEVEL=INFO
