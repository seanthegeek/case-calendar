# CourtListener API token — get one at https://www.courtlistener.com/profile/api/
COURTLISTENER_TOKEN=

# LLM Provider: "anthropic", "gemini", or "openai"
# This is the GLOBAL override — when set, it forces ONE provider for
# BOTH the extraction track and the case-summary track. Leave it unset
# (the default) to let each track auto-detect its own provider from the
# API keys you've supplied, which is the recommended setup.
#
# With no LLM_* var set and all keys present, the two tracks resolve to
# DIFFERENT providers, because the auto-detect key priority is per-track:
#   - extraction track:    gemini > anthropic > openai  -> picks Gemini
#   - summary track:       anthropic > gemini > openai  -> picks Anthropic
# So the default split is Gemini for extraction, Anthropic for summaries.
# Gemini's deadline-classification accuracy now leads the comparison
# table (the extraction prompt names the substantive federal-procedure
# deadline classes for every provider, so they're no longer left to a
# model's intrinsic priors) while staying cheaper and faster; Anthropic
# keeps the summary track because it pulls more case-distinguishing
# detail. See model-comparison/SCORECARD.md for the measured numbers.
#
# To force one provider for both tracks, uncomment LLM_PROVIDER. To pin
# just one track, use the per-track overrides below instead.
# LLM_PROVIDER=anthropic

# Extraction track override (per-entry classification + verify pass +
# dedupe). Beats both LLM_PROVIDER and the auto-detect for the
# extraction track only. The extraction default is already Gemini (see
# above), so set this only to pin a DIFFERENT extraction provider —
# e.g. "anthropic" if your caseload includes substantive deadline
# classes the prompt's ruleset doesn't yet enumerate and you want to
# verify Gemini handles them before relying on it. Leave unset for the
# default (Gemini when its key is present).
# LLM_EXTRACTION_PROVIDER=anthropic

# Model override for the extraction track. Defaults below are
# small/fast — structured extraction doesn't need flagship reasoning.
#   Anthropic: claude-haiku-4-5
#   Gemini:    gemini-3.1-flash-lite
#   OpenAI:    gpt-5.4-nano
# LLM_MODEL=claude-haiku-4-5

# Case-summary track (opt-in via case_summaries.enabled in config.yaml).
# Synthesis-heavy, low-volume — defaults to a higher tier than
# extraction. The summary default is already Anthropic (auto-detect
# priority anthropic > gemini > openai when no LLM_* var is set), so set
# this only to pin a DIFFERENT summary provider. LLM_SUMMARY_PROVIDER
# beats both LLM_PROVIDER and the auto-detect for the summary track
# only; config-level `case_summaries.provider` / `.model` win over
# either env var if set.
#   Anthropic: claude-sonnet-4-6
#   Gemini:    gemini-2.5-pro
#   OpenAI:    gpt-5.4
# LLM_SUMMARY_PROVIDER=anthropic
# LLM_SUMMARY_MODEL=claude-sonnet-4-6

# API Keys — set the one matching your provider
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Webhook receiver secret (only needed if you run `case-calendar serve` for
# real-time push from CourtListener). Generate one with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# CASE_CALENDAR_WEBHOOK_SECRET=

# --- Calendar push (all optional) -------------------------------------------
#
# Google Calendar: there is NO env var. Put the path to your downloaded
# OAuth-installed-app JSON in config.yaml as `google_credentials_path`.
# First run of `case-calendar emit --push-gcal` opens a browser and caches
# the refresh token at `google_token_path` (default
# tokens/google-token.json, relative to the project directory).
#
# Microsoft 365 / Outlook: the Application (client) ID of your Entra
# "public client" app registration. This is a PUBLIC identifier, not a
# secret — put it here OR in config.yaml as `m365_client_id` (config
# wins if both are set). The interactive first-run of
# `case-calendar emit --push-m365` opens a browser to grant
# Calendars.ReadWrite and caches the AuthenticationRecord at
# `m365_token_path` (default tokens/m365-token.json) plus the
# OS keyring (DPAPI / Keychain / libsecret).
# M365_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Optional logging level
# LOG_LEVEL=INFO
