# CourtListener API token — get one at https://www.courtlistener.com/profile/api/
COURTLISTENER_TOKEN=

# LLM Provider: "anthropic", "gemini", "openai", or "ollama" (local)
# This is the GLOBAL override — when set, it forces ONE provider for
# BOTH the extraction track and the case-summary track. Leave it unset
# (the default) to let each track auto-detect its own provider from the
# API keys you've supplied, which is the recommended setup.
#
# With no LLM_* var set and all keys present, the two tracks resolve to
# DIFFERENT providers, because the auto-detect key priority is per-track:
#   - extraction track:    gemini > anthropic > openai  -> picks Gemini
#   - summary track:       anthropic > gemini > openai  -> picks Anthropic
# So the default split is Gemini for extraction, Anthropic for summaries.
# Gemini's deadline-classification accuracy now leads the comparison
# table (the extraction prompt names the substantive federal-procedure
# deadline classes for every provider, so they're no longer left to a
# model's intrinsic priors) while staying cheaper and faster; Anthropic
# keeps the summary track because it pulls more case-distinguishing
# detail. See model-comparison/SCORECARD.md for the measured numbers.
#
# To force one provider for both tracks, uncomment LLM_PROVIDER. To pin
# just one track, use the per-track overrides below instead.
# LLM_PROVIDER=anthropic

# Extraction track override (per-entry classification + verify pass +
# dedupe). Beats both LLM_PROVIDER and the auto-detect for the
# extraction track only. The extraction default is already Gemini (see
# above), so set this only to pin a DIFFERENT extraction provider —
# e.g. "anthropic" if your caseload includes substantive deadline
# classes the prompt's ruleset doesn't yet enumerate and you want to
# verify Gemini handles them before relying on it. Leave unset for the
# default (Gemini when its key is present).
# LLM_EXTRACTION_PROVIDER=anthropic

# Model override for the extraction track. Defaults below are
# small/fast — structured extraction doesn't need flagship reasoning.
#   Anthropic: claude-haiku-4-5
#   Gemini:    gemini-3.1-flash-lite
#   OpenAI:    gpt-5.4-nano
# LLM_MODEL=gemini-3.1-flash-lite

# Structured output (schema-enforced JSON on the extraction call). DEFAULT ON
# for all providers — it hard-constrains the output shape via each provider's
# native mechanism (OpenAI json_schema, Gemini response_schema, Ollama `format`,
# Anthropic tool-use). It's neutral-or-better on accuracy everywhere measured
# and cuts tokens on hosted models. Set to a falsy value to opt OUT — mainly for
# a non-Ollama OpenAI-compatible server whose strict json_schema is unverified.
# LLM_STRUCTURED_OUTPUT=0

# Case-summary track (opt-in via case_summaries.enabled in config.yaml).
# Synthesis-heavy, low-volume — defaults to a higher tier than
# extraction. The summary default is already Anthropic (auto-detect
# priority anthropic > gemini > openai when no LLM_* var is set), so set
# this only to pin a DIFFERENT summary provider. LLM_SUMMARY_PROVIDER
# beats both LLM_PROVIDER and the auto-detect for the summary track
# only; config-level `case_summaries.provider` / `.model` win over
# either env var if set.
#   Anthropic: claude-sonnet-4-6
#   Gemini:    gemini-2.5-pro
#   OpenAI:    gpt-5.4
# LLM_SUMMARY_PROVIDER=anthropic
# LLM_SUMMARY_MODEL=claude-sonnet-4-6

# API Keys — set the one matching your provider
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- Local models via Ollama (optional) -------------------------------------
#
# Ollama (https://ollama.com) runs open models locally and serves an
# OpenAI-compatible API, so it slots in as a fourth provider with no API key
# and no per-token cost. It's opt-in only: there's no key to auto-detect from,
# so you must select it explicitly. Either globally:
#   LLM_PROVIDER=ollama
# or per-track (mix local + hosted — e.g. local extraction, hosted summaries):
#   LLM_EXTRACTION_PROVIDER=ollama
#   LLM_SUMMARY_PROVIDER=ollama
# Pick the model with the usual LLM_MODEL / LLM_SUMMARY_MODEL (defaults to
# gpt-oss:20b for both tracks — ~13 GB, fits a 16 GB card, the best-scoring
# local extractor in the benchmark; override with whatever you've `ollama
# pull`ed — e.g. LLM_MODEL=gemma4:e4b on a smaller 12 GB card, or
# LLM_MODEL=gemma4:31b on a 32 GB+ card for higher-quality summaries).
#
# OLLAMA_BASE_URL  — where the Ollama server listens. On REAL Ollama the code
#                    auto-detects it (via /api/show) and uses the native
#                    /api/chat endpoint — per-request thinking control AND native
#                    `format` structured output — regardless of a trailing /v1
#                    (it's stripped). The OpenAI-compatible /v1 shim is used only
#                    for a non-Ollama server (LM Studio / vLLM, no /api/show) or
#                    when OLLAMA_USE_OPENAI_COMPAT=1.
# OLLAMA_NUM_CTX   — context window in tokens. Local models default to a small
#                    window (~4K–8K) and SILENTLY TRUNCATE longer prompts,
#                    which the summary track WILL exceed. Raise it here, or
#                    (more reliably) bake `PARAMETER num_ctx` into a Modelfile.
# OLLAMA_THINK_BUDGET    — reasoning headroom (tokens) added on top of the
#                    answer allowance for a thinking model on real Ollama
#                    (default 8192). It's a runaway guard, not a cost lever
#                    (local inference is free); raise it only if a model's
#                    reasoning is being truncated mid-thought.
# OLLAMA_FORCE_NO_THINK  — set to 1 to disable a (boolean-thinking) model's
#                    reasoning entirely and bound its output — the escape hatch
#                    for a model that runs away or is too slow. No-op for the
#                    level-only gpt-oss family. Off by default (reasoning ON is
#                    more accurate; see docs/local-llms.md).
# See docs/local-llms.md for the full walkthrough.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_NUM_CTX=32768

# Webhook receiver secret (only needed if you run `case-calendar serve` for
# real-time push from CourtListener). Generate one with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# CASE_CALENDAR_WEBHOOK_SECRET=

# --- Calendar push (all optional) -------------------------------------------
#
# Google Calendar: there is NO env var. Put the path to your downloaded
# OAuth-installed-app JSON in config.yaml as `google_credentials_path`.
# A one-time `case-calendar setup gcal` opens a browser and caches the
# refresh token at `google_token_path` (default tokens/google-token.json,
# relative to the project directory); after that, `sync` / `serve` / `emit`
# push automatically whenever the token cache file is present.
#
# Microsoft 365 / Outlook: the Application (client) ID of your Entra
# "public client" app registration. This is a PUBLIC identifier, not a
# secret — put it here OR in config.yaml as `m365_client_id` (config
# wins if both are set). A one-time `case-calendar setup m365` opens a
# browser to grant Calendars.ReadWrite and caches the AuthenticationRecord
# at `m365_token_path` (default tokens/m365-token.json) plus the
# OS keyring (DPAPI / Keychain / libsecret); after that, push runs
# automatically when the cache is present.
# M365_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Optional logging level
# LOG_LEVEL=INFO
